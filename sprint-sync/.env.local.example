# =============================================================================
# SprintSync — Environment Variables
#
# Copy this file to .env.local and fill in the values from your Supabase project.
# NEVER commit .env.local to version control.
# =============================================================================

# Supabase project URL
# Found in: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key
# Found in: Supabase Dashboard → Settings → API → Project API keys → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Application base URL (for OAuth callbacks)
# In development: http://localhost:3000
# In production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set to 'true' to enable the Google SSO button on the auth page.
# Requires Google OAuth to be configured in your Supabase project.
# Leave unset or set to 'false' to hide the button.
NEXT_PUBLIC_GOOGLE_SSO_ENABLED=false

# Prisma connection pooling URL (port 5432)
# Used for runtime queries via Prisma Client
# Found in: Supabase Dashboard → Settings → Database → Connection string → URI mode
# Replace [PASSWORD] with your database password
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Prisma direct URL for migrations (port 6543)
# Used by `prisma migrate dev` and `prisma db push` — bypasses connection pooler
# Same as DATABASE_URL but with port 6543
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.your-project-ref.supabase.co:6543/postgres

# =============================================================================
# Optional: Seed script user IDs
# Set these to real auth.users UUIDs before running `npm run seed`
# =============================================================================
# SEED_FACILITATOR_USER_ID=your-facilitator-user-uuid
# SEED_MEMBER_USER_ID=your-member-user-uuid
